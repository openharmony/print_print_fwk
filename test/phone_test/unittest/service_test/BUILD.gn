ohos_unittest("scan_task_test") {
  module_out_path = module_output_path
  include_dirs = [
    "${print_path}/frameworks/models/scan_models/include",
    "${print_path}/services/scan_service/include",
    "${print_utils_path}/include",
  ]

  sources = [
    "${_test_path}/unittest/service_test/scan_task_test.cpp",
  ]

  deps = [
    "${print_path}/services/scan_service:scan_service_test",
  ]

  external_deps = [
    "image_framework:image_ndk",
    "image_framework:image_native",
    "googletest:gtest_main",
    "googletest:gmock_main",
  ]

  cflags = [
    "-Dprivate=public",
    "-Dprotected=public",
  ]
}

group("unittest") {
  testonly = true

  deps = []

  deps += [ ":print_service_test" ]
  deps += [ ":scan_service_test" ]
  deps += [ ":scan_task_test" ]
}

import("//base/print/print_fwk/print.gni")
import("//build/test.gni")

module_output_path = unit_test_output_path

ohos_unittest("print_ability_manager_adapter_test") {
  module_out_path = module_output_path
  include_dirs = [
    "${print_path}/frameworks/ability_manager_adapter/include",
    "${print_utils_path}/include",
    "../service_test/mock",
  ]

  sources = [
    "ability_manager_adapter_test.cpp",
  ]

  deps = [
    "${print_path}/frameworks/ability_manager_adapter:print_ability_manager_adapter",
  ]

  external_deps = [
    "ability_base:want",
    "ability_runtime:ability_manager",
    "c_utils:utils",
    "googletest:gmock_main",
    "hilog:libhilog",
    "ipc:ipc_core",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
  ]

  cflags_cc = [
    "-DUNIT_TEST",
    "-Dprivate=public",
    "-Dprotected=public",
  ]
}

import("//base/print/print_fwk/print.gni")
import("//build/config/features.gni")
import("//build/ohos.gni")
import("//build/test.gni")

##############################fuzztest##########################################
ohos_fuzztest("AbilityManagerAdapterFuzzTest") {
  module_out_path = "${fuzz_test_output_path}/concurrent"

  fuzz_config_file = "${print_path}/test/fuzztest/abilitymanageradapter_fuzzer"

  include_dirs = [
    "${print_path}/frameworks/ability_manager_adapter/include",
    "${print_path}/interfaces/kits/napi/print_napi/include",
    "${print_utils_path}/include",
  ]

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]

  cflags_cc = []

  deps = [
    "${print_path}/etc/init:printservice.rc",
    "${print_path}/frameworks/ability_manager_adapter:print_ability_manager_adapter",
    "${print_path}/frameworks/innerkitsimpl/print_impl:print_client",
  ]

  sources = [ "${print_path}/test/fuzztest/abilitymanageradapter_fuzzer/ability_manager_adapter_fuzzer.cpp" ]

  external_deps = [
    "ability_base:base",
    "ability_base:want",
    "ability_base:zuri",
    "ability_runtime:ability_manager",
    "ability_runtime:abilitykit_native",
    "access_token:libaccesstoken_sdk",
    "access_token:libnativetoken",
    "access_token:libtoken_setproc",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "hilog:libhilog",
    "hisysevent:libhisysevent",
    "init:libbegetutil",
    "ipc:ipc_core",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
  ]
}

###############################################################################
group("fuzztest") {
  testonly = true
  deps = []
  deps += [
    # deps file
    ":AbilityManagerAdapterFuzzTest",
  ]
}
###############################################################################
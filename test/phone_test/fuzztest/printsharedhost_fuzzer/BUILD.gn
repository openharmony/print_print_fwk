import("//base/print/print_fwk/print.gni")
import("//build/config/features.gni")
import("//build/ohos.gni")
import("//build/test.gni")

_test_path = "${print_path}/test/phone_test"
_service_path = "${print_path}/services/print_service_phone"

##############################fuzztest##########################################
ohos_fuzztest("PrintSharedHostFuzzTest") {
  module_out_path = "${fuzz_test_output_path}/concurrent"

  fuzz_config_file = "${_test_path}/fuzztest/printsharedhost_fuzzer"

  include_dirs = [
    "${print_path}/frameworks/models/print_models/include",
    "${print_path}/frameworks/innerkitsimpl/print_impl/include",
    "${print_path}/frameworks/ohprint/include",
    "${_service_path}/include",
    "${print_utils_path}/include",
  ]

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]

  cflags_cc = []

  deps = [
    "${print_path}/frameworks/innerkitsimpl/print_impl:print_client",
    "${print_path}/frameworks/models/print_models:print_models",
  ]

  sources = [
    "${_test_path}/fuzztest/printsharedhost_fuzzer/printsharedhost_fuzzer.cpp",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]
}

###############################################################################
group("fuzztest") {
  testonly = true
  deps = []
  deps += [
    # deps file
    ":PrintSharedHostFuzzTest",
  ]
}
###############################################################################

import("//build/config/features.gni")
import("//build/test.gni")
import("../../../../print.gni")

##############################fuzztest##########################################
ohos_fuzztest("RemoteServiceFuzzTest") {
  module_output_path = module_output_path_phone_fuzztest
  fuzz_config_file = "//base/print/print_print_fwk/test/phone_test/fuzztest/remoteservice_fuzzer"
  
  include_dirs = [
    "../../../../services/print_service_phone/include",
    "../../../../services/print_service_phone/include/remote",
    "../../../../utils/include",
    "../../../../frameworks/ohprint/include",
    "//commonlibrary/c_utils/base/include",
    "//base/hiviewdfx/hilog/interfaces/native/innerkits/include",
    "//foundation/ability/ability_runtime/interfaces/innerkits/ability_manager/include",
    "//foundation/ability/ability_runtime/interfaces/innerkits/extension_manager/include",
    "//foundation/distributeddatamgr/appdatamgr/interfaces/innerkits/dataobs_provider/include",
    "//foundation/appexecfwk/standard/interfaces/innerkits/bundlemgr/native/include",
    "//foundation/communication/ipc/interfaces/innerkits/ipc_core/include",
    "//third_party/json/include",
  ]
  
  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]
  
  sources = [
    "remoteservice_fuzzer.cpp",
  ]
  
  deps = [
    "../../../../services/print_service_phone:print_service_phone",
    "../../../../utils:print_utils",
    "//foundation/ability/ability_runtime:ability_manager",
    "//foundation/ability/ability_runtime:extension_manager",
    "//foundation/hiviewdfx/hilog:libhilog",
    "//third_party/json:json",
  ]
  
  external_deps = [
    "ability_base:want",
    "ability_runtime:ability_manager",
    "ability_runtime:extension_manager",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:bundle_framework_native",
    "c_utils:utils",
    "commonlibrary:c_utils",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]
  
  if (print_fwk_feature_remote_service) {
    cflags += [ "-DREMOTE_SERVICE_ENABLE" ]
  }
}

group("fuzztest") {
  testonly = true
  deps = []
  
  if (print_fwk_feature_remote_service) {
    deps += [ ":RemoteServiceFuzzTest" ]
  }
}
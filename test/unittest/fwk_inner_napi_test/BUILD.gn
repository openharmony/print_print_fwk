import("//base/print/print_fwk/print.gni")
import("//build/test.gni")

_test_path = "${print_path}/test"
_service_path = "${print_path}/services/print_service"
_scan_service_path = "${print_path}/services/scan_service"

module_output_path = unit_test_output_path

ohos_unittest("print_fwk_inner_napi_test") {
  module_out_path = module_output_path
  include_dirs = [
    "${_test_path}/unittest/fwk_inner_napi_test/mock",
    "../service_test/mock",
    "${print_path}/frameworks/innerkitsimpl/print_impl/include",
    "${print_path}/frameworks/innerkitsimpl/scan_impl/include",
    "${print_path}/frameworks/models/print_models/include",
    "${print_path}/frameworks/models/scan_models/include",
    "${_service_path}/print_service/include",
    "${_scan_service_path}/include",
    "${print_utils_path}/include",
  ]

  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
    blocklist = "${print_path}/cfi_blocklist.txt"
  }

  cflags_cc = [ "-DUNIT_TEST" ]

  sources = [
    "${_test_path}/unittest/fwk_inner_napi_test/print_attributes_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_callback_stub_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_extension_callback_stub_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_extension_info_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_job_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_manager_client_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_margin_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_page_size_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_preview_attribute_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_range_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_resolution_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_sa_death_recipient_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_service_proxy_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_sync_load_callback_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_utils_ext_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_utils_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/printer_capability_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/printer_info_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/printer_preferences_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/ppd_info_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/print_shared_host_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/scan_manager_client_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/scan_models_test.cpp",
    "${_test_path}/unittest/fwk_inner_napi_test/watermark_callback_stub_test.cpp",
  ]

  deps = [
    "${print_path}/etc/init:printservice.rc",
    "${print_path}/frameworks/helper/print_helper:print_helper",
    "${print_path}/frameworks/innerkitsimpl/print_impl:print_client",
    "${print_path}/frameworks/innerkitsimpl/scan_impl:scan_client",
    "${print_path}/frameworks/kits/extension:print_extension_framework",
    "${print_path}/frameworks/kits/extension:print_extension_module",
    "${print_path}/frameworks/models/print_models:print_models",
    "${print_path}/frameworks/models/scan_models:scan_models",
    "${print_path}/interfaces/kits/jsnapi/print_extension:printextensionability_napi",
    "${print_path}/interfaces/kits/jsnapi/print_extensionctx:printextensioncontext_napi",
    "${print_path}/interfaces/kits/napi/print_napi:print_napi",
    "${print_path}/profile:print_sa_profiles",
    "${print_path}/services/print_service:print_service_test",
    "${print_path}/services/scan_service:scan_service_test",
  ]

  external_deps = [
    "ability_base:want",
    "ability_base:zuri",
    "ability_runtime:ability_manager",
    "ability_runtime:abilitykit_native",
    "ability_runtime:data_ability_helper",
    "ability_runtime:napi_base_context",
    "c_utils:utils",
    "common_event_service:cesfwk_innerkits",
    "eventhandler:libeventhandler",
    "googletest:gmock_main",
    "hilog:libhilog",
    "ipc:ipc_core",
    "jsoncpp:jsoncpp",
    "napi:ace_napi",
    "node:node_header_notice",
    "libuv:uv",
    "ace_engine:ace_uicontent",
    "resource_management:global_resmgr",
    "samgr:samgr_proxy",
  ]

  if (print_fwk_feature_kia_interceptor) {
    cflags_cc += [ "-DKIA_INTERCEPTOR_ENABLE" ]
    sources += [
      "${_test_path}/unittest/fwk_inner_napi_test/kia_interceptor_callback_stub_test.cpp",
    ]
  }
}

group("unittest") {
  testonly = true

  deps = []

  deps += [ ":print_fwk_inner_napi_test" ]
}
